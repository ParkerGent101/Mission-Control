# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Plaid (bank account sync - connect from the Finance card or onboarding)
# https://dashboard.plaid.com - client_id is shared across environments; the secret
# differs per environment. Use PLAID_ENV=sandbox with the Sandbox secret for a free
# Plaid setup and test credentials (user_good/pass_good). Use production only after
# you have Production access and a Production secret for real bank data.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# OAuth banks (Fidelity, Chase): set this to the exact HTTPS URL you registered as an
# allowed redirect URI in the Plaid dashboard. Leave blank until registered.
PLAID_REDIRECT_URI=

# Optional: Google Calendar / Drive / Sheets
# Download OAuth credentials from Google Cloud Console -> APIs -> Credentials
# Use an OAuth 2.0 Client ID for a Desktop app and save it as:
#   data/credentials.json
# After first auth, Mission Control stores the refresh token at:
#   data/drive_token.json
# Sheet IDs/URLs configured in the app are stored locally at:
#   data/drive_config.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_PROJECT_ID=mission-control-496004
FINANCE_SHEET_ID=
# Email to share year-rollover-generated finance files with (optional)
FINANCE_OWNER_EMAIL=
GCS_BUCKET=

# ── Sign-in (Google identity + MFA) ─────────────────────────────────────────
# Login uses "Sign in with Google" (reuses the OAuth client above). Add this
# redirect URI to that client in Google Cloud Console -> Credentials:
#   http://localhost:5000/api/auth/google/callback           (local dev)
#   https://<your-cloud-run-url>/api/auth/google/callback     (production)
# Only these Google accounts may log in (comma-separated):
ALLOWED_LOGIN_EMAILS=parkergent7@gmail.com
# How long a session lasts before re-auth is required (days):
SESSION_LIFETIME_DAYS=7
# Break-glass ONLY: re-enable the legacy shared password. Leave false/unset in
# production so the app is password-free (required for Plaid MFA attestations).
ALLOW_PASSWORD_LOGIN=false

# Optional: deployment
# Legacy shared password — only used when ALLOW_PASSWORD_LOGIN=true (break-glass).
DASHBOARD_PASSWORD=changeme
DATA_DIR=./data
