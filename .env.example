# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Plaid (bank account sync via onboarding)
# Sign up free at https://dashboard.plaid.com — use "sandbox" for testing
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: Google Calendar / Drive / Sheets
# Download OAuth credentials from Google Cloud Console -> APIs -> Credentials
# Use an OAuth 2.0 Client ID for a Desktop app and save it as:
#   data/credentials.json
# After first auth, Mission Control stores the refresh token at:
#   data/drive_token.json
# Sheet IDs/URLs configured in the app are stored locally at:
#   data/drive_config.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_PROJECT_ID=mission-control-496004
FINANCE_SHEET_ID=
# Email to share year-rollover-generated finance files with (optional)
FINANCE_OWNER_EMAIL=
GCS_BUCKET=

# Optional: deployment
DASHBOARD_PASSWORD=changeme
DATA_DIR=./data
